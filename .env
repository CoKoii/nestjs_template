# =========================
# 应用基础配置
# =========================
# 服务监听端口
PORT=3000

# 默认缓存过期时间，单位毫秒
CACHE_TTL_MS=60000

# Cache Manager 命名空间，用于隔离不同业务缓存
CACHE_NAMESPACE=cache

# =========================
# 数据库基础配置
# =========================
# 数据库类型；当前支持 mysql / postgres
DB_TYPE=postgres

# Access Token 过期时间，例如 15m / 1h / 1d
JWT_ACCESS_EXPIRES_IN=15m

# Refresh Token 过期时间，例如 7d / 30d
JWT_REFRESH_EXPIRES_IN=7d

# 是否落盘日志到 logs 目录
LOG_ON=true

# 日志级别，可选：error / warn / info / http / verbose / debug / silly
LOG_LEVEL=info

# =========================
# Redis 默认行为
# =========================
# Redis 数据库编号，默认使用 0
REDIS_DB=0

# Redis key 前缀，避免与其他系统的 key 冲突
REDIS_KEY_PREFIX=nestjs_template:

# =========================
# 邮件服务
# =========================
# 是否启用邮件发送
MAIL_ENABLED=true

# QQ 个人邮箱 SMTP 地址
MAIL_HOST=smtp.qq.com

# QQ 邮箱 SSL 常用端口
MAIL_PORT=465

# 是否直接使用 SSL/TLS
MAIL_SECURE=true

# SMTP 登录用户名
MAIL_USER=2655257336@qq.com

# SMTP 授权码
MAIL_PASS=acxuawzqwzsaecbe

# 发件人名称
MAIL_FROM_NAME=陈平安

# 默认发件邮箱地址
MAIL_FROM_ADDRESS=2655257336@qq.com
