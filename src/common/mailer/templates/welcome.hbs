<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}}</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 24px;
      background: #f3f4f6;
      font-family: Arial, Helvetica, sans-serif;
      color: #111827;
    "
  >
    <div
      style="
        max-width: 640px;
        margin: 0 auto;
        padding: 32px;
        background: #ffffff;
        border-radius: 16px;
      "
    >
      <p style="margin: 0 0 16px; font-size: 14px; color: #6b7280">Hello,</p>
      <h1 style="margin: 0 0 20px; font-size: 28px; line-height: 1.3">
        {{title}}
      </h1>
      <p style="margin: 0 0 16px; font-size: 16px; line-height: 1.7">
        {{message}}
      </p>

      {{#if actionUrl}}
        <p style="margin: 28px 0">
          <a
            href="{{actionUrl}}"
            style="
              display: inline-block;
              padding: 12px 20px;
              background: #111827;
              border-radius: 999px;
              color: #ffffff;
              font-size: 14px;
              text-decoration: none;
            "
          >
            {{actionLabel}}
          </a>
        </p>
      {{/if}}

      <p style="margin: 24px 0 0; font-size: 12px; color: #9ca3af">
        Sent by NestJS Template Mailer
      </p>
    </div>
  </body>
</html>
